# Yosai MLOps Environment Configuration
# Copy this to .env and customize values

# ============== Application ==============
APP_NAME="Yōsai Inference API"
APP_VERSION="0.1.0"
ENVIRONMENT=development  # development, staging, production

# ============== API Server ==============
API__HOST=0.0.0.0
API__PORT=8000
API__WORKERS=1
API__RELOAD=false
API__LOG_LEVEL=info
API__RATE_LIMIT_PER_MINUTE=60

# Security - add your API keys here (comma-separated)
# Example: api_key_1,api_key_2
API__API_KEYS=

# Model settings
API__MODEL_WARMUP=true
API__MAX_IMAGE_SIZE_MB=10

# ============== MLflow ==============
MLFLOW__TRACKING_URI=file:./mlruns
MLFLOW__EXPERIMENT_NAME=yosai-edge-mlops
MLFLOW__MODEL_NAME=yosai-anomaly-detector

# MinIO/S3 settings (if using remote MLflow)
MLFLOW__S3_ENDPOINT_URL=http://127.0.0.1:9000
MLFLOW__AWS_ACCESS_KEY_ID=minioadmin
MLFLOW__AWS_SECRET_ACCESS_KEY=minioadmin
MLFLOW__AWS_DEFAULT_REGION=us-east-1